# MCP-Atlassian Server Environment Configuration
# Copy this file to 'mcp-atlassian.env' and fill in your actual credentials

# Jira Cloud Configuration
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_USERNAME=your_jira_username_here
JIRA_URL=https://your-company.atlassian.net

# OAuth Configuration
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
OAUTH_REDIRECT_URI=http://localhost:9000/oauth/callback

# Server Configuration
SERVER_PORT=9000
SSE_ENABLED=true
